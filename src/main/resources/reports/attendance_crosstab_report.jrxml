<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="AttendanceCrossTabReport" language="java" pageWidth="842" pageHeight="595" orientation="Landscape"
              columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">

    <!-- ========== Styles ========== -->
    <style name="Title" fontSize="22" isBold="true" forecolor="#1E293B"/>
    <style name="ColumnHeader" fontSize="9" isBold="true" forecolor="#1E293B" backcolor="#DBEAFE" hAlign="Center" vAlign="Middle"/>
    <style name="Detail" fontSize="9" forecolor="#334155"/>
    <style name="DetailAlt" fontSize="9" forecolor="#334155" backcolor="#F8FAFC"/>
    <style name="Footer" fontSize="8" forecolor="#94A3B8"/>
    <style name="SummaryLabel" fontSize="11" isBold="true" forecolor="#64748B"/>
    <style name="SummaryValue" fontSize="14" isBold="true" forecolor="#2563EB"/>

    <!-- ========== Fields ========== -->
    <field name="institute_name" class="java.lang.String"/>
    <field name="course_code" class="java.lang.String"/>
    <field name="course_name" class="java.lang.String"/>
    <field name="total_sessions" class="java.lang.Long"/>
    <field name="present_count" class="java.lang.Long"/>
    <field name="absent_count" class="java.lang.Long"/>
    <field name="attendance_percentage" class="java.math.BigDecimal"/>
    <field name="total_students" class="java.lang.Long"/>

    <!-- ========== Title ========== -->
    <title>
        <band height="70">
            <rectangle>
                <reportElement mode="Opaque" x="0" y="0" width="802" height="4" backcolor="#DBEAFE"/>
            </rectangle>
            <textField>
                <reportElement x="20" y="10" width="500" height="18" forecolor="#64748B"/>
                <textElement>
                    <font size="11" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["Training Management System"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="20" y="30" width="600" height="28" forecolor="#1E293B"/>
                <textElement>
                    <font size="20" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["Attendance Summary Report"]]></textFieldExpression>
            </textField>
            <textField pattern="dd MMMM yyyy, HH:mm">
                <reportElement x="580" y="45" width="200" height="18" forecolor="#94A3B8"/>
                <textElement textAlignment="Right">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <!-- ========== Page Header ========== -->
    <pageHeader>
        <band height="22">
            <staticText>
                <reportElement x="0" y="0" width="30" height="22" style="ColumnHeader"/>
                <text><![CDATA[#]]></text>
            </staticText>
            <staticText>
                <reportElement x="30" y="0" width="150" height="22" style="ColumnHeader"/>
                <text><![CDATA[Institute]]></text>
            </staticText>
            <staticText>
                <reportElement x="180" y="0" width="120" height="22" style="ColumnHeader"/>
                <text><![CDATA[Course]]></text>
            </staticText>
            <staticText>
                <reportElement x="300" y="0" width="80" height="22" style="ColumnHeader"/>
                <text><![CDATA[Sessions]]></text>
            </staticText>
            <staticText>
                <reportElement x="380" y="0" width="60" height="22" style="ColumnHeader"/>
                <text><![CDATA[Present]]></text>
            </staticText>
            <staticText>
                <reportElement x="440" y="0" width="60" height="22" style="ColumnHeader"/>
                <text><![CDATA[Absent]]></text>
            </staticText>
            <staticText>
                <reportElement x="500" y="0" width="80" height="22" style="ColumnHeader"/>
                <text><![CDATA[Attendance %]]></text>
            </staticText>
            <staticText>
                <reportElement x="580" y="0" width="80" height="22" style="ColumnHeader"/>
                <text><![CDATA[Students]]></text>
            </staticText>
        </band>
    </pageHeader>

    <!-- ========== Detail ========== -->
    <detail>
        <band height="20">
            <rectangle>
                <reportElement x="0" y="0" width="802" height="20" backcolor="#F8FAFC">
                    <printWhenExpression><![CDATA[$V{REPORT_COUNT} % 2 == 0]]></printWhenExpression>
                </reportElement>
            </rectangle>
            <textField>
                <reportElement x="0" y="0" width="30" height="20" style="Detail"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$V{REPORT_COUNT}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="30" y="0" width="150" height="20" style="Detail"/>
                <textElement/>
                <textFieldExpression><![CDATA[$F{institute_name} != null ? $F{institute_name} : "N/A"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="180" y="0" width="120" height="20" style="Detail"/>
                <textElement/>
                <textFieldExpression><![CDATA[$F{course_code} + " - " + $F{course_name}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="300" y="0" width="80" height="20" style="Detail"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{total_sessions}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="380" y="0" width="60" height="20" style="Detail"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{present_count}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="440" y="0" width="60" height="20" style="Detail"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{absent_count}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="500" y="0" width="80" height="20" style="Detail"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{attendance_percentage} != null ? $F{attendance_percentage} + "%" : "0%"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="580" y="0" width="80" height="20" style="Detail"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{total_students}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <!-- ========== Page Footer ========== -->
    <pageFooter>
        <band height="22">
            <line>
                <reportElement x="0" y="0" width="802" height="1" forecolor="#E2E8F0"/>
            </line>
            <textField>
                <reportElement x="0" y="4" width="400" height="14" style="Footer"/>
                <textElement/>
                <textFieldExpression><![CDATA["Generated: " + new java.util.Date()]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="400" y="4" width="402" height="14" style="Footer"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER} + " of "]]></textFieldExpression>
            </textField>
            <textField evaluationTime="Report">
                <reportElement x="400" y="4" width="402" height="14" style="Footer"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[" " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

    <!-- ========== Summary ========== -->
    <summary>
        <band height="35">
            <line>
                <reportElement x="20" y="0" width="762" height="1" forecolor="#6A1B9A"/>
            </line>
            <staticText>
                <reportElement x="20" y="8" width="150" height="18" style="SummaryLabel"/>
                <text><![CDATA[Total Records:]]></text>
            </staticText>
            <textField>
                <reportElement x="175" y="8" width="50" height="18" style="SummaryValue"/>
                <textElement/>
                <textFieldExpression><![CDATA[$V{REPORT_COUNT}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="230" y="12" width="200" height="14" style="Footer"/>
                <text><![CDATA[attendance record(s)]]></text>
            </staticText>
        </band>
    </summary>

</jasperReport>
