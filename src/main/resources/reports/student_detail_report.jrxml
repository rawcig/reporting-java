<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="StudentDetailReport" language="java" pageWidth="842" pageHeight="595" orientation="Landscape"
              columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">

    <!-- ========== Styles ========== -->
    <style name="Title" fontSize="22" isBold="true" forecolor="#1E293B"/>
    <style name="ColumnHeader" fontSize="9" isBold="true" forecolor="#1E293B" backcolor="#DBEAFE" hAlign="Center" vAlign="Middle"/>
    <style name="Detail" fontSize="9" forecolor="#334155"/>
    <style name="DetailAlt" fontSize="9" forecolor="#334155" backcolor="#F8FAFC"/>
    <style name="Footer" fontSize="8" forecolor="#94A3B8"/>
    <style name="GroupHeader" fontSize="13" isBold="true" forecolor="#1E293B"/>
    <style name="GroupTotal" fontSize="10" isBold="true" forecolor="#2563EB"/>
    <style name="SummaryLabel" fontSize="11" isBold="true" forecolor="#64748B"/>
    <style name="SummaryValue" fontSize="14" isBold="true" forecolor="#2563EB"/>

    <!-- ========== Fields ========== -->
    <field name="student_code" class="java.lang.String"/>
    <field name="student_name" class="java.lang.String"/>
    <field name="gender" class="java.lang.String"/>
    <field name="phone" class="java.lang.String"/>
    <field name="email" class="java.lang.String"/>
    <field name="course_code" class="java.lang.String"/>
    <field name="course_name" class="java.lang.String"/>
    <field name="teacher_name" class="java.lang.String"/>
    <field name="enrollment_date" class="java.sql.Date"/>
    <field name="payment_status" class="java.lang.String"/>
    <field name="payment_amount" class="java.math.BigDecimal"/>
    <field name="completion_status" class="java.lang.String"/>
    <field name="progress_percentage" class="java.math.BigDecimal"/>
    <field name="final_grade" class="java.lang.String"/>
    <field name="certificate_issued" class="java.lang.Boolean"/>
    <field name="institute_name" class="java.lang.String"/>

    <!-- ========== Variables ========== -->
    <variable name="StudentTotalPaid" resetType="Group" calculation="Sum" resetGroup="StudentGroup" class="java.math.BigDecimal">
        <variableExpression><![CDATA[$F{payment_amount} != null ? $F{payment_amount} : java.math.BigDecimal.ZERO]]></variableExpression>
    </variable>

    <!-- ========== Groups ========== -->
    <group name="StudentGroup">
        <groupExpression><![CDATA[$F{student_code}]]></groupExpression>
        <groupHeader>
            <band height="60">
                <rectangle>
                    <reportElement mode="Opaque" x="0" y="0" width="802" height="58" backcolor="#F1F5F9"/>
                </rectangle>
                <rectangle>
                    <reportElement mode="Opaque" x="0" y="0" width="5" height="58" backcolor="#DBEAFE"/>
                </rectangle>
                <textField>
                    <reportElement x="18" y="6" width="300" height="20" style="GroupHeader"/>
                    <textElement/>
                    <textFieldExpression><![CDATA[$F{student_code} + " - " + $F{student_name}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="18" y="30" width="100" height="14" style="Detail"/>
                    <textElement/>
                    <textFieldExpression><![CDATA["Gender: " + $F{gender}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="130" y="30" width="150" height="14" style="Detail"/>
                    <textElement/>
                    <textFieldExpression><![CDATA["Phone: " + ($F{phone} != null ? $F{phone} : "-")]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="300" y="30" width="250" height="14" style="Detail"/>
                    <textElement/>
                    <textFieldExpression><![CDATA["Email: " + ($F{email} != null ? $F{email} : "-")]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="580" y="30" width="200" height="14" style="Detail"/>
                    <textElement textAlignment="Right"/>
                    <textFieldExpression><![CDATA["Institute: " + ($F{institute_name} != null ? $F{institute_name} : "-")]]></textFieldExpression>
                </textField>
            </band>
        </groupHeader>
        <groupFooter>
            <band height="20">
                <rectangle>
                    <reportElement mode="Opaque" x="0" y="0" width="802" height="18" backcolor="#EFF6FF"/>
                </rectangle>
                <staticText>
                    <reportElement x="15" y="2" width="120" height="14" style="GroupTotal"/>
                    <textElement/>
                    <text><![CDATA[Total Paid:]]></text>
                </staticText>
                <textField>
                    <reportElement x="140" y="2" width="80" height="14" style="GroupTotal"/>
                    <textElement/>
                    <textFieldExpression><![CDATA[$V{StudentTotalPaid}]]></textFieldExpression>
                </textField>
                <staticText>
                    <reportElement x="230" y="2" width="100" height="14" style="Footer"/>
                    <textElement/>
                    <text><![CDATA[enrollments:]]></text>
                </staticText>
                <textField>
                    <reportElement x="330" y="2" width="40" height="14" style="GroupTotal"/>
                    <textElement/>
                    <textFieldExpression><![CDATA[$V{StudentGroup_COUNT}]]></textFieldExpression>
                </textField>
            </band>
        </groupFooter>
    </group>

    <!-- ========== Title ========== -->
    <title>
        <band height="70">
            <rectangle>
                <reportElement mode="Opaque" x="0" y="0" width="802" height="4" backcolor="#DBEAFE"/>
            </rectangle>
            <textField>
                <reportElement x="20" y="10" width="500" height="18" forecolor="#64748B"/>
                <textElement>
                    <font size="11" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["Training Management System"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="20" y="30" width="600" height="28" forecolor="#1E293B"/>
                <textElement>
                    <font size="20" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["Student Detail Report"]]></textFieldExpression>
            </textField>
            <textField pattern="dd MMMM yyyy, HH:mm">
                <reportElement x="580" y="45" width="200" height="18" forecolor="#94A3B8"/>
                <textElement textAlignment="Right">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <!-- ========== Page Header ========== -->
    <pageHeader>
        <band height="22">
            <staticText>
                <reportElement x="0" y="0" width="25" height="22" style="ColumnHeader"/>
                <textElement/>
                <text><![CDATA[#]]></text>
            </staticText>
            <staticText>
                <reportElement x="25" y="0" width="60" height="22" style="ColumnHeader"/>
                <textElement/>
                <text><![CDATA[Course]]></text>
            </staticText>
            <staticText>
                <reportElement x="85" y="0" width="120" height="22" style="ColumnHeader"/>
                <textElement/>
                <text><![CDATA[Course Name]]></text>
            </staticText>
            <staticText>
                <reportElement x="205" y="0" width="85" height="22" style="ColumnHeader"/>
                <textElement/>
                <text><![CDATA[Instructor]]></text>
            </staticText>
            <staticText>
                <reportElement x="290" y="0" width="60" height="22" style="ColumnHeader"/>
                <textElement/>
                <text><![CDATA[Enrolled]]></text>
            </staticText>
            <staticText>
                <reportElement x="350" y="0" width="55" height="22" style="ColumnHeader"/>
                <textElement/>
                <text><![CDATA[Payment]]></text>
            </staticText>
            <staticText>
                <reportElement x="405" y="0" width="55" height="22" style="ColumnHeader"/>
                <textElement/>
                <text><![CDATA[Amount]]></text>
            </staticText>
            <staticText>
                <reportElement x="460" y="0" width="55" height="22" style="ColumnHeader"/>
                <textElement/>
                <text><![CDATA[Status]]></text>
            </staticText>
            <staticText>
                <reportElement x="515" y="0" width="50" height="22" style="ColumnHeader"/>
                <textElement/>
                <text><![CDATA[Progress]]></text>
            </staticText>
            <staticText>
                <reportElement x="565" y="0" width="40" height="22" style="ColumnHeader"/>
                <textElement/>
                <text><![CDATA[Grade]]></text>
            </staticText>
            <staticText>
                <reportElement x="605" y="0" width="65" height="22" style="ColumnHeader"/>
                <textElement/>
                <text><![CDATA[Certificate]]></text>
            </staticText>
        </band>
    </pageHeader>

    <!-- ========== Detail ========== -->
    <detail>
        <band height="18">
            <rectangle>
                <reportElement x="0" y="0" width="802" height="18" backcolor="#F8FAFC">
                    <printWhenExpression><![CDATA[$V{REPORT_COUNT} % 2 == 0]]></printWhenExpression>
                </reportElement>
            </rectangle>
            <textField>
                <reportElement x="0" y="0" width="25" height="18" style="Detail"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$V{REPORT_COUNT}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="25" y="0" width="60" height="18" style="Detail"/>
                <textElement verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{course_code}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="85" y="0" width="120" height="18" style="Detail"/>
                <textElement verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{course_name}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="205" y="0" width="85" height="18" style="Detail"/>
                <textElement verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{teacher_name} != null ? $F{teacher_name} : "-"]]></textFieldExpression>
            </textField>
            <textField pattern="dd/MM/yyyy">
                <reportElement x="290" y="0" width="60" height="18" style="Detail"/>
                <textElement verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{enrollment_date}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="350" y="0" width="55" height="18" style="Detail"/>
                <textElement verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{payment_status}]]></textFieldExpression>
            </textField>
            <textField pattern="$#,##0.00">
                <reportElement x="405" y="0" width="55" height="18" style="Detail"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{payment_amount}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="460" y="0" width="55" height="18" style="Detail"/>
                <textElement verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{completion_status}]]></textFieldExpression>
            </textField>
            <textField pattern="#0.0'%'" >
                <reportElement x="515" y="0" width="50" height="18" style="Detail"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{progress_percentage}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="565" y="0" width="40" height="18" style="Detail"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{final_grade} != null ? $F{final_grade} : "-"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="605" y="0" width="65" height="18" style="Detail"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{certificate_issued} ? "Yes" : "No"]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <!-- ========== Page Footer ========== -->
    <pageFooter>
        <band height="22">
            <line>
                <reportElement x="0" y="0" width="802" height="1" forecolor="#E2E8F0"/>
            </line>
            <textField>
                <reportElement x="0" y="4" width="400" height="14" style="Footer"/>
                <textElement/>
                <textFieldExpression><![CDATA["Generated: " + new java.util.Date()]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="400" y="4" width="402" height="14" style="Footer"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER} + " of "]]></textFieldExpression>
            </textField>
            <textField evaluationTime="Report">
                <reportElement x="400" y="4" width="402" height="14" style="Footer"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[" " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

    <!-- ========== Summary ========== -->
    <summary>
        <band height="35">
            <line>
                <reportElement x="20" y="0" width="762" height="1" forecolor="#6A1B9A"/>
            </line>
            <staticText>
                <reportElement x="20" y="8" width="150" height="18" style="SummaryLabel"/>
                <textElement/>
                <text><![CDATA[Total Records:]]></text>
            </staticText>
            <textField>
                <reportElement x="175" y="8" width="50" height="18" style="SummaryValue"/>
                <textElement/>
                <textFieldExpression><![CDATA[$V{REPORT_COUNT}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="230" y="12" width="200" height="14" style="Footer"/>
                <textElement/>
                <text><![CDATA[student enrollment record(s)]]></text>
            </staticText>
        </band>
    </summary>

</jasperReport>
